{
  "_comment": "Multi-account config for claude-usage-fleet. Copy to ~/.claude/accounts.json and edit. Each 'path' must point at a CLAUDE_CONFIG_DIR (a directory containing a 'projects/' subdirectory). If this file is absent, the tool falls back to scanning ~/.claude/projects/ only.",

  "_windows_wsl_note": "From a Windows host you can track WSL distros by pointing at UNC paths like //wsl$/<distro-name>/home/<user>/.claude. Forward slashes are fine — pathlib.Path handles them on Windows. The WSL distro must be running for the scan to resolve; stopped distros emit a SKIP warning and scan continues without failing.",

  "_plan_note": "Valid plan values: api, pro, max_5x, max_20x, or null. null/api disables threshold alerts for that account but it still appears in the dashboard. Plan limits drive the 5h progress-bar denominator (pro=44k, max_5x=88k, max_20x=220k tokens).",

  "accounts": [
    {"name": "win11",     "path": "~/.claude",                                "plan": null},
    {"name": "kali",      "path": "//wsl$/kali-linux/home/USERNAME/.claude",  "plan": null},
    {"name": "blackarch", "path": "//wsl$/BlackArch/home/USERNAME/.claude",   "plan": null},
    {"name": "parrot",    "path": "//wsl$/ParrotOS/home/USERNAME/.claude",    "plan": null}
  ],

  "thresholds": {
    "warn": 0.75,
    "critical": 0.95
  },

  "webhooks": [
    {"url": "https://ntfy.sh/your-topic-here", "on": ["warn", "critical"]}
  ]
}
